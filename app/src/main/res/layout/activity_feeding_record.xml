<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFE8F5E9"
    tools:ignore="Overdraw">

    <!-- 顶部标题栏：小棚养虾记录表 -->
    <TextView
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#FF4CAF50"
        android:gravity="center"
        android:text="@string/title_feeding_record"
        android:textColor="#FFFFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 表头区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#FF4CAF50">

        <TextView
            android:id="@+id/header_fixed_date"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/header_date"
            android:textSize="12sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:id="@+id/header_scroll_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never" />
    </LinearLayout>

    <!-- 数据区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/record_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <FrameLayout
            android:id="@+id/loading_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">
            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center" />
        </FrameLayout>
    </FrameLayout>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <TextView
            android:id="@+id/nav_home"
            style="@style/BottomNavItem"
            android:text="@string/nav_home" />

        <TextView
            android:id="@+id/nav_record"
            style="@style/BottomNavItem"
            android:text="@string/nav_record" />

        <TextView
            android:id="@+id/nav_check"
            style="@style/BottomNavItem"
            android:text="@string/nav_check" />

        <TextView
            android:id="@+id/nav_mix"
            style="@style/BottomNavItem"
            android:text="@string/nav_mix" />

        <TextView
            android:id="@+id/nav_my"
            style="@style/BottomNavItem"
            android:text="@string/nav_my" />
    </LinearLayout>
</LinearLayout>
