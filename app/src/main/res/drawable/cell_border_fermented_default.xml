<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 浅灰色背景 -->
    <solid android:color="#F0F0F0" />

    <!-- 黑色边框，0.5dp -->
    <stroke 
        android:width="0.5dp" 
        android:color="#FF000000" />

    <!-- 圆角（可选） -->
    <corners 
        android:radius="0dp" />

    <!-- 内边距 -->
    <padding 
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp" />
</shape>
