<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 浅绿色背景，表示参与计算 -->
    <solid android:color="#F0F8F0" />

    <!-- 褐色边框，3dp，表示参与计算 -->
    <stroke 
        android:width="3dp" 
        android:color="#FF6E511E" />

    <!-- 圆角 -->
    <corners 
        android:radius="2dp" />

    <!-- 内边距 -->
    <padding 
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp" />
</shape>
